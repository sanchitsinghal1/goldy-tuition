// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Contact {
  id          String   @id @default(cuid())
  parentName  String
  studentName String
  studentClass String
  area        String
  phone       String
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id          String   @id @default(cuid())
  parentName  String
  studentName String
  rating      Int
  review      String
  area        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
